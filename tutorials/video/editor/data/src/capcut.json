{
  "version": "1.0.0",

  "project": {
    "id": "project_001",
    "name": "My Video",

    "width": 1920,
    "height": 1080,

    "fps": {
      "num": 30,
      "den": 1
    },

    "duration": 600000,

    "backgroundColor": "#000000"
  },

  "resources": {
    "videos": [
      {
        "id": "video_1",
        "src": "file:///videos/a.mp4",

        "duration": 120000,

        "width": 1920,
        "height": 1080,

        "fps": 29.97,

        "hasAudio": true,

        "audioChannels": 2
      }
    ],

    "audios": [
      {
        "id": "audio_1",
        "src": "file:///audios/bgm.mp3",
        "duration": 180000
      }
    ],

    "images": [
      {
        "id": "image_1",
        "src": "file:///images/cover.png",
        "width": 1080,
        "height": 1920
      }
    ],

    "fonts": [
      {
        "id": "font_1",
        "family": "PingFang SC"
      }
    ],

    "effects": [
      {
        "id": "effect_blur",
        "type": "blur"
      },

      {
        "id": "effect_glow",
        "type": "glow"
      }
    ],

    "transitions": [
      {
        "id": "transition_fade",
        "type": "fade"
      }
    ]
  },

  "timeline": {
    "duration": 600000,

    "tracks": [
      {
        "id": "track_video_main",
        "type": "video",
        "index": 0,

        "clips": [
          {
            "id": "clip_video_1",

            "type": "video",

            "resourceId": "video_1",

            "timeline": {
              "start": 0,
              "duration": 10000
            },

            "source": {
              "start": 5000,
              "duration": 10000
            },

            "transform": {
              "x": 0,
              "y": 0,

              "anchorX": 0.5,
              "anchorY": 0.5,

              "scaleX": 1,
              "scaleY": 1,

              "rotation": 0,

              "opacity": 1
            },

            "crop": {
              "left": 0,
              "top": 0,
              "right": 0,
              "bottom": 0
            },

            "mask": {
              "enabled": true,
              "type": "circle",
              "feather": 20,
              "invert": false
            },

            "blendMode": "normal",

            "speed": {
              "mode": "curve",

              "points": [
                {
                  "time": 0,
                  "speed": 1
                },
                {
                  "time": 2000,
                  "speed": 0.5
                },
                {
                  "time": 5000,
                  "speed": 2
                }
              ]
            },

            "audio": {
              "enabled": true,

              "volume": {
                "db": 0
              },

              "fadeIn": 500,
              "fadeOut": 500
            },

            "effects": [
              {
                "id": "clip_effect_1",
                "effectId": "effect_blur",

                "enabled": true,

                "params": {
                  "radius": 12
                }
              }
            ],

            "animations": {
              "in": {
                "type": "fade_in",
                "duration": 300
              },

              "out": {
                "type": "fade_out",
                "duration": 300
              },

              "combo": {
                "type": "shake"
              }
            },

            "keyframes": {
              "transform.scaleX": [
                {
                  "time": 0,
                  "value": 1,
                  "easing": "linear"
                },
                {
                  "time": 3000,
                  "value": 1.5,
                  "easing": "easeOut"
                }
              ],

              "transform.rotation": [
                {
                  "time": 0,
                  "value": 0
                },
                {
                  "time": 5000,
                  "value": 180
                }
              ]
            },

            "transition": {
              "next": {
                "transitionId": "transition_fade",
                "duration": 500
              }
            }
          }
        ]
      },

      {
        "id": "track_video_overlay",
        "type": "video",
        "index": 1,

        "clips": [
          {
            "id": "clip_image_1",

            "type": "image",

            "resourceId": "image_1",

            "timeline": {
              "start": 2000,
              "duration": 4000
            },

            "transform": {
              "x": 100,
              "y": 200,

              "scaleX": 0.8,
              "scaleY": 0.8,

              "rotation": 15,

              "opacity": 0.9
            },

            "blendMode": "screen"
          }
        ]
      },

      {
        "id": "track_text",
        "type": "text",
        "index": 2,

        "clips": [
          {
            "id": "text_1",

            "type": "text",

            "timeline": {
              "start": 1000,
              "duration": 3000
            },

            "content": "Hello World",

            "style": {
              "fontId": "font_1",

              "fontSize": 72,

              "fontWeight": 700,

              "color": "#ffffff",

              "strokeColor": "#000000",
              "strokeWidth": 4,

              "shadow": {
                "enabled": true,
                "blur": 10,
                "offsetX": 0,
                "offsetY": 4
              }
            },

            "layout": {
              "x": 540,
              "y": 1400,
              "width": 800,
              "height": 200,

              "align": "center"
            },

            "animation": {
              "in": "typewriter",
              "out": "fade"
            }
          }
        ]
      },

      {
        "id": "track_audio",
        "type": "audio",
        "index": 0,

        "clips": [
          {
            "id": "bgm_1",

            "type": "audio",

            "resourceId": "audio_1",

            "timeline": {
              "start": 0,
              "duration": 30000
            },

            "source": {
              "start": 0,
              "duration": 30000
            },

            "volume": {
              "db": -8
            },

            "fadeIn": 1000,
            "fadeOut": 1000
          }
        ]
      }
    ]
  },

  "renderGraph": {
    "nodes": [
      {
        "id": "decode_video_1",
        "type": "decoder"
      },

      {
        "id": "blur_1",
        "type": "blur"
      },

      {
        "id": "composite_1",
        "type": "composite"
      },

      {
        "id": "output_1",
        "type": "output"
      }
    ],

    "edges": [
      {
        "from": "decode_video_1",
        "to": "blur_1"
      },

      {
        "from": "blur_1",
        "to": "composite_1"
      },

      {
        "from": "composite_1",
        "to": "output_1"
      }
    ]
  },

  "cache": {
    "preview": {
      "enabled": true,
      "resolution": "540p"
    }
  },

  "export": {
    "width": 1080,
    "height": 1920,

    "fps": 30,

    "videoCodec": "h264",

    "audioCodec": "aac",

    "bitrate": 8000000,

    "audioBitrate": 320000,

    "colorSpace": "bt709"
  }
}
